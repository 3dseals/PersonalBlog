{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hexo Server (本地预览)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/hexo/bin/hexo",
      "args": [
        "server"
      ],
      "console": "integratedTerminal",
      "restart": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
